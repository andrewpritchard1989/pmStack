#!/usr/bin/env bash
# pmstack-review-read — read review log and config for dashboard
# Usage: pmstack-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/pmstack-slug" 2>/dev/null)"
PMSTACK_HOME="${PMSTACK_HOME:-$HOME/.pmstack}"
cat "$PMSTACK_HOME/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/pmstack-config" get skip_cpo_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
